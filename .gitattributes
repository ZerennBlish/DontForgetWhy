# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Binary files (explicit so they're never treated as text)
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.mp3 binary
*.wav binary
*.mp4 binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.keystore binary
*.jks binary
*.pdf binary
