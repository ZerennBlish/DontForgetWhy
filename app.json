{
  "expo": {
    "name": "DontForgetWhy",
    "slug": "DontForgetWhy",
    "version": "1.14.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#121220"
      },
      "predictiveBackGestureEnabled": false,
      "versionCode": 31,
      "package": "com.zerennblish.DontForgetWhy",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "scheme": "dontforgetwhy",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/withNotifee",
      "./plugins/withAlarmWake",
      "./plugins/withAlarmChannel",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "DetailedWidget",
              "label": "DFW",
              "minWidth": "180dp",
              "minHeight": "180dp",
              "resizeMode": "horizontal|vertical",
              "description": "Timer presets with durations and alarm schedules",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "NotepadWidget",
              "label": "DFW Notes",
              "minWidth": "300dp",
              "minHeight": "280dp",
              "resizeMode": "horizontal|vertical",
              "description": "Quick notes at a glance",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "CalendarWidget",
              "label": "DFW Calendar",
              "minWidth": "250dp",
              "minHeight": "280dp",
              "resizeMode": "horizontal|vertical",
              "description": "Monthly calendar with event indicators",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "MicWidget",
              "label": "DFW Mic",
              "minWidth": "40dp",
              "minHeight": "40dp",
              "resizeMode": "horizontal|vertical",
              "description": "Quick voice memo recording",
              "updatePeriodMillis": 0
            }
          ]
        }
      ],
      "expo-asset",
      "expo-audio",
      "expo-sharing",
      "expo-sqlite",
      "expo-document-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "93348f85-09e8-4f25-8159-63d10f9b1d1b"
      }
    },
    "owner": "zerennblish"
  }
}
